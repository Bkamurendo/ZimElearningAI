# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
# Sign up at https://account.africastalking.com
# Use 'sandbox' for AFRICASTALKING_USERNAME during development
AFRICASTALKING_API_KEY=your_at_api_key_here
AFRICASTALKING_USERNAME=your_at_username_here
# Optional: registered sender ID (defaults to ZimLearn)
AT_SENDER_ID=ZimLearn

# ── Vercel Cron protection ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Set this same value in Vercel project environment variables
CRON_SECRET=your_random_secret_here

# ── Paynow Zimbabwe ───────────────────────────────────────────────────────────
PAYNOW_INTEGRATION_ID=your_integration_id_here
PAYNOW_INTEGRATION_KEY=your_integration_key_here
PAYNOW_MERCHANT_EMAIL=your_merchant_email_here

# ── Flutterwave ───────────────────────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key_here
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here

# ── OpenAI (AI Tutor / MaFundi) ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Internal API (server-to-server calls) ─────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=your_internal_api_key_here
